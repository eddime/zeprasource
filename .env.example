# Copy to .env and fill in values from your OAuth app registrations.
# See docs/OAUTH.md for setup steps.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Stripe Checkout (secret key from Dashboard → Developers → API keys)
# Products use lookup keys: zepra_migration_trot | gallop | stampede
STRIPE_SECRET_KEY=
