# Copy to .env and fill in values from your OAuth app registrations.
# See docs/OAUTH.md for setup steps.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Stripe Checkout — see docs/STRIPE.md
# Price lookup_key zepra_migration_per_gb; metadata free_migration_gb (e.g. 2)
STRIPE_SECRET_KEY=

# Zepra Server — signs lifetime licenses (required for Lifetime purchases)
# Run: cd server && bun run dev
ZEPRA_SERVER_URL=http://127.0.0.1:8787
# ZEPRA_API_KEY=   # if set on the server
