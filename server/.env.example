# HTTP port (Railway/Fly set PORT automatically)
PORT=8787

# Public base URL of this service, no trailing slash
# e.g. https://api.zepra.app
ZEPRA_SERVER_PUBLIC_URL=

# Stripe secret key (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=

# Webhook signing secret (Dashboard → Webhooks → endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=

# Signs migration launch tickets — min 32 chars, never ship to the desktop app
ZEPRA_LICENSE_SIGNING_SECRET=

# Where Stripe redirects after payment (must match electrobun urlSchemes)
ZEPRA_PAYMENT_RETURN_SCHEME=zepra

# Optional: require this header on API routes (X-Zepra-Api-Key)
# ZEPRA_API_KEY=
