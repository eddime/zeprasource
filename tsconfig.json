{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["bun"],
		"paths": {
			"@/*": ["./src/mainview/*"],
			"@shared/*": ["./src/shared/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts", "electrobun.config.ts", "vite.config.ts"]
}
